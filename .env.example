# ═══════════════════════════════════════════════════════════════
# Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Backend API endpoint (required)
API_ENDPOINT=https://your-backend-api.com

# Optional: Custom rate limits (requests per minute)
# RATE_LIMIT_IP=100
# RATE_LIMIT_PATH=50
